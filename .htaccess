<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(?:db|lib|locales|tests)(?:/|$) - [F,L]
</IfModule>

<FilesMatch "(^\.|^config(?:\.local(?:\.example)?)?\.php$|^Dockerfile$|^docker-compose\.yml$|^README\.md$|^TODO\.md$|^.*\.(?:sql|dump|csv|bak)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-Frame-Options "DENY"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header set Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self'"
</IfModule>
